---
/**
 * Cubes Component
 * ===============
 * Interactive 3D cube grid with mouse-tracking tilt, auto-animation, and ripple effects.
 *
 * Inspired by Can Tastemel's work for the lambda.ai landing page
 * https://cantastemel.com
 *
 * Translated from React to native Astro for optimal performance.
 */

interface Props {
  /** Number of cubes per row/column */
  gridSize?: number;
  /** Fixed cube size in pixels (if not set, cubes scale to fit container) */
  cubeSize?: number;
  /** Maximum tilt angle in degrees */
  maxAngle?: number;
  /** Radius of effect (in grid units) */
  radius?: number;
  /** GSAP easing function */
  easing?: string;
  /** Animation durations */
  duration?: { enter: number; leave: number };
  /** Gap between cells */
  cellGap?: number | { row: number; col: number };
  /** Border style for cube faces */
  borderStyle?: string;
  /** Background color for cube faces */
  faceColor?: string;
  /** Box shadow for cube faces */
  shadow?: boolean | string;
  /** Enable idle auto-animation */
  autoAnimate?: boolean;
  /** Enable ripple effect on click */
  rippleOnClick?: boolean;
  /** Color of ripple effect */
  rippleColor?: string;
  /** Speed multiplier for ripple (higher = faster) */
  rippleSpeed?: number;
}

const {
  gridSize = 8,
  cubeSize,
  maxAngle = 45,
  radius = 3,
  easing = "power3.out",
  duration = { enter: 0.3, leave: 0.6 },
  cellGap,
  borderStyle = "2px solid var(--accent-regular)",
  faceColor = "var(--gray-999)",
  shadow = false,
  autoAnimate = true,
  rippleOnClick = true,
  rippleColor = "var(--accent-light)",
  rippleSpeed = 2,
} = Astro.props;

// Calculate gap values
const colGap =
  typeof cellGap === "number"
    ? `${cellGap}px`
    : cellGap?.col !== undefined
      ? `${cellGap.col}px`
      : "5%";
const rowGap =
  typeof cellGap === "number"
    ? `${cellGap}px`
    : cellGap?.row !== undefined
      ? `${cellGap.row}px`
      : "5%";

// Generate grid cells
const cells = Array.from({ length: gridSize * gridSize }, (_, i) => ({
  row: Math.floor(i / gridSize),
  col: i % gridSize,
}));

// Inline styles for dynamic values
const sceneStyle = [
  `grid-template-columns: ${cubeSize ? `repeat(${gridSize}, ${cubeSize}px)` : `repeat(${gridSize}, 1fr)`}`,
  `grid-template-rows: ${cubeSize ? `repeat(${gridSize}, ${cubeSize}px)` : `repeat(${gridSize}, 1fr)`}`,
  `column-gap: ${colGap}`,
  `row-gap: ${rowGap}`,
].join(";");

const wrapperStyle = [
  `--cube-face-border: ${borderStyle}`,
  `--cube-face-bg: ${faceColor}`,
  `--cube-face-shadow: ${shadow === true ? "0 0 6px rgba(0,0,0,.5)" : shadow || "none"}`,
  cubeSize ? `width: ${gridSize * cubeSize}px` : "",
  cubeSize ? `height: ${gridSize * cubeSize}px` : "",
]
  .filter(Boolean)
  .join(";");

// Pass config to client script via data attributes
const configData = JSON.stringify({
  gridSize,
  maxAngle,
  radius,
  easing,
  duration,
  autoAnimate,
  rippleOnClick,
  rippleColor,
  rippleSpeed,
  faceColor,
});
---

<div class="cubes-wrapper" style={wrapperStyle} data-cubes-config={configData}>
  <div class="cubes-scene" style={sceneStyle}>
    {
      cells.map(({ row, col }) => (
        <div class="cube" data-row={row} data-col={col}>
          <div class="cube-face cube-face--top" />
          <div class="cube-face cube-face--bottom" />
          <div class="cube-face cube-face--left" />
          <div class="cube-face cube-face--right" />
          <div class="cube-face cube-face--front" />
          <div class="cube-face cube-face--back" />
        </div>
      ))
    }
  </div>
</div>

<style>
  .cubes-wrapper {
    --cube-perspective: 99999999px;
    --cube-face-border: 2px solid var(--accent-regular);
    --cube-face-bg: var(--gray-999);
    --cube-face-shadow: none;

    position: relative;
    width: 100%;
    aspect-ratio: 1 / 1;
    height: auto;
  }

  .cubes-scene {
    display: grid;
    width: 100%;
    height: 100%;
    perspective: var(--cube-perspective);
    grid-auto-rows: 1fr;
  }

  .cube {
    position: relative;
    width: 100%;
    height: 100%;
    aspect-ratio: 1 / 1;
    transform-style: preserve-3d;
    will-change: transform;
  }

  /* Expand hit area for smoother mouse tracking */
  .cube::before {
    content: "";
    position: absolute;
    top: -36px;
    right: -36px;
    bottom: -36px;
    left: -36px;
  }

  .cube-face {
    position: absolute;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--cube-face-bg);
    border: var(--cube-face-border);
    box-shadow: var(--cube-face-shadow);
    opacity: 1;
    backface-visibility: hidden;
    will-change: background-color;
  }

  .cube-face--top {
    transform: translateY(-50%) rotateX(90deg);
  }

  .cube-face--bottom {
    transform: translateY(50%) rotateX(-90deg);
  }

  .cube-face--left {
    transform: translateX(-50%) rotateY(-90deg);
  }

  .cube-face--right {
    transform: translateX(50%) rotateY(90deg);
  }

  .cube-face--back,
  .cube-face--front {
    transform: rotateY(-90deg) translateX(50%) rotateY(90deg);
  }

  /* Reduce grid density on mobile for performance */
  @media (max-width: 768px) {
    .cubes-wrapper {
      width: 100%;
    }
  }
</style>

<script>
  import gsap from "gsap";

  interface CubesConfig {
    gridSize: number;
    maxAngle: number;
    radius: number;
    easing: string;
    duration: { enter: number; leave: number };
    autoAnimate: boolean;
    rippleOnClick: boolean;
    rippleColor: string;
    rippleSpeed: number;
    faceColor: string;
  }

  class CubesController {
    private scene: HTMLElement;
    private config: CubesConfig;
    private cubes: HTMLDivElement[];
    private rafId: number | null = null;
    private idleTimer: ReturnType<typeof setTimeout> | null = null;
    private userActive = false;
    private simPos = { x: 0, y: 0 };
    private simTarget = { x: 0, y: 0 };
    private simRAFId: number | null = null;
    private abortController: AbortController;

    constructor(wrapper: HTMLElement) {
      const configStr = wrapper.dataset.cubesConfig;
      if (!configStr) throw new Error("Cubes config not found");

      this.config = JSON.parse(configStr) as CubesConfig;
      this.scene = wrapper.querySelector(".cubes-scene") as HTMLElement;
      this.cubes = Array.from(this.scene.querySelectorAll<HTMLDivElement>(".cube"));
      this.abortController = new AbortController();

      this.init();
    }

    private init(): void {
      this.bindEvents();
      if (this.config.autoAnimate) {
        this.startAutoAnimation();
      }
    }

    private bindEvents(): void {
      const signal = this.abortController.signal;

      this.scene.addEventListener("pointermove", this.onPointerMove, { signal });
      this.scene.addEventListener("pointerleave", this.resetAll, { signal });
      this.scene.addEventListener("click", this.onClick, { signal });
      this.scene.addEventListener("touchmove", this.onTouchMove, { passive: false, signal } as AddEventListenerOptions);
      this.scene.addEventListener("touchstart", this.onTouchStart, { passive: true, signal });
      this.scene.addEventListener("touchend", this.onTouchEnd, { passive: true, signal });
    }

    private tiltAt = (rowCenter: number, colCenter: number): void => {
      const { radius, maxAngle, easing } = this.config;
      const { enter: enterDur, leave: leaveDur } = this.config.duration;

      this.cubes.forEach((cube) => {
        const r = Number(cube.dataset.row);
        const c = Number(cube.dataset.col);
        const dist = Math.hypot(r - rowCenter, c - colCenter);

        if (dist <= radius) {
          const pct = 1 - dist / radius;
          const angle = pct * maxAngle;
          gsap.to(cube, {
            duration: enterDur,
            ease: easing,
            overwrite: true,
            rotateX: -angle,
            rotateY: angle,
          });
        } else {
          gsap.to(cube, {
            duration: leaveDur,
            ease: "power3.out",
            overwrite: true,
            rotateX: 0,
            rotateY: 0,
          });
        }
      });
    };

    private onPointerMove = (e: PointerEvent): void => {
      this.userActive = true;
      if (this.idleTimer) clearTimeout(this.idleTimer);

      const rect = this.scene.getBoundingClientRect();
      const cellW = rect.width / this.config.gridSize;
      const cellH = rect.height / this.config.gridSize;
      const colCenter = (e.clientX - rect.left) / cellW;
      const rowCenter = (e.clientY - rect.top) / cellH;

      if (this.rafId) cancelAnimationFrame(this.rafId);
      this.rafId = requestAnimationFrame(() => this.tiltAt(rowCenter, colCenter));

      this.idleTimer = setTimeout(() => {
        this.userActive = false;
      }, 3000);
    };

    private resetAll = (): void => {
      const { leave: leaveDur } = this.config.duration;
      this.cubes.forEach((cube) =>
        gsap.to(cube, {
          duration: leaveDur,
          rotateX: 0,
          rotateY: 0,
          ease: "power3.out",
        })
      );
    };

    private onTouchMove = (e: TouchEvent): void => {
      e.preventDefault();
      this.userActive = true;
      if (this.idleTimer) clearTimeout(this.idleTimer);

      const rect = this.scene.getBoundingClientRect();
      const cellW = rect.width / this.config.gridSize;
      const cellH = rect.height / this.config.gridSize;

      const touch = e.touches[0];
      const colCenter = (touch.clientX - rect.left) / cellW;
      const rowCenter = (touch.clientY - rect.top) / cellH;

      if (this.rafId) cancelAnimationFrame(this.rafId);
      this.rafId = requestAnimationFrame(() => this.tiltAt(rowCenter, colCenter));

      this.idleTimer = setTimeout(() => {
        this.userActive = false;
      }, 3000);
    };

    private onTouchStart = (): void => {
      this.userActive = true;
    };

    private onTouchEnd = (): void => {
      this.resetAll();
    };

    private onClick = (e: MouseEvent | TouchEvent): void => {
      if (!this.config.rippleOnClick) return;

      const rect = this.scene.getBoundingClientRect();
      const cellW = rect.width / this.config.gridSize;
      const cellH = rect.height / this.config.gridSize;

      const clientX =
        (e as MouseEvent).clientX ||
        ((e as TouchEvent).touches && (e as TouchEvent).touches[0].clientX);
      const clientY =
        (e as MouseEvent).clientY ||
        ((e as TouchEvent).touches && (e as TouchEvent).touches[0].clientY);

      const colHit = Math.floor((clientX - rect.left) / cellW);
      const rowHit = Math.floor((clientY - rect.top) / cellH);

      const baseRingDelay = 0.15;
      const baseAnimDur = 0.3;
      const baseHold = 0.6;

      const spreadDelay = baseRingDelay / this.config.rippleSpeed;
      const animDuration = baseAnimDur / this.config.rippleSpeed;
      const holdTime = baseHold / this.config.rippleSpeed;

      // Group cubes by ring distance from click point
      const rings: Record<number, HTMLDivElement[]> = {};
      this.cubes.forEach((cube) => {
        const r = Number(cube.dataset.row);
        const c = Number(cube.dataset.col);
        const dist = Math.hypot(r - rowHit, c - colHit);
        const ring = Math.round(dist);
        if (!rings[ring]) rings[ring] = [];
        rings[ring].push(cube);
      });

      // Get computed ripple color (resolve CSS variables)
      const computedRippleColor = getComputedStyle(this.scene).getPropertyValue("--accent-light").trim() || this.config.rippleColor;
      const computedFaceColor = getComputedStyle(this.scene).getPropertyValue("--gray-999").trim() || this.config.faceColor;

      // Animate rings outward
      Object.keys(rings)
        .map(Number)
        .sort((a, b) => a - b)
        .forEach((ring) => {
          const delay = ring * spreadDelay;
          const faces = rings[ring].flatMap((cube) =>
            Array.from(cube.querySelectorAll<HTMLElement>(".cube-face"))
          );

          gsap.to(faces, {
            backgroundColor: computedRippleColor,
            duration: animDuration,
            delay,
            ease: "power3.out",
          });
          gsap.to(faces, {
            backgroundColor: computedFaceColor,
            duration: animDuration,
            delay: delay + animDuration + holdTime,
            ease: "power3.out",
          });
        });
    };

    private startAutoAnimation(): void {
      const { gridSize } = this.config;
      this.simPos = {
        x: Math.random() * gridSize,
        y: Math.random() * gridSize,
      };
      this.simTarget = {
        x: Math.random() * gridSize,
        y: Math.random() * gridSize,
      };

      const speed = 0.02;

      const loop = (): void => {
        if (!this.userActive) {
          this.simPos.x += (this.simTarget.x - this.simPos.x) * speed;
          this.simPos.y += (this.simTarget.y - this.simPos.y) * speed;
          this.tiltAt(this.simPos.y, this.simPos.x);

          if (Math.hypot(this.simPos.x - this.simTarget.x, this.simPos.y - this.simTarget.y) < 0.1) {
            this.simTarget = {
              x: Math.random() * gridSize,
              y: Math.random() * gridSize,
            };
          }
        }
        this.simRAFId = requestAnimationFrame(loop);
      };

      this.simRAFId = requestAnimationFrame(loop);
    }

    public destroy(): void {
      this.abortController.abort();
      if (this.rafId) cancelAnimationFrame(this.rafId);
      if (this.simRAFId) cancelAnimationFrame(this.simRAFId);
      if (this.idleTimer) clearTimeout(this.idleTimer);
    }
  }

  // Initialize all cube instances
  function initCubes(): void {
    document.querySelectorAll<HTMLElement>(".cubes-wrapper").forEach((wrapper) => {
      // Prevent double initialization
      if (wrapper.dataset.initialized) return;
      wrapper.dataset.initialized = "true";
      new CubesController(wrapper);
    });
  }

  // Run on page load and after Astro page transitions
  initCubes();
  document.addEventListener("astro:page-load", initCubes);
</script>
