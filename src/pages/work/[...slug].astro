---
import { type CollectionEntry, getCollection } from "astro:content";
import { render } from "astro:content";
import { Image } from "astro:assets";

import BaseLayout from "../../layouts/BaseLayout.astro";
import ContactCTA from "../../components/ContactCTA.astro";
import Hero from "../../components/Hero.astro";
import Icon from "../../components/Icon.astro";
import Pill from "../../components/Pill.astro";

interface Props {
  entry: CollectionEntry<"work">;
}

export async function getStaticPaths() {
  const work = await getCollection("work");
  return work.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<BaseLayout title={entry.data.title} description={entry.data.description}>
  <div class="work-container">
    <div class="stack gap-20">
      <div class="stack gap-15">
        <header>
          <div class="wrapper stack gap-2">
            <a class="back-link" href="/work/">
              <Icon icon="arrow-left" /> Work
            </a>

            <div class="hero-wrapper">
              <Hero title={entry.data.title} align="start">
                <div class="details">
                  <div class="tags">
                    {entry.data.tags.map((t) => <Pill>{t}</Pill>)}
                  </div>
                  <p class="description">{entry.data.description}</p>
                </div>
              </Hero>
            </div>
          </div>
        </header>

        <main class="wrapper">
          <div class="stack gap-10 content-wrapper">
            {
              entry.data.img && (
                <div class="hero-image-container">
                  <Image
                    src={entry.data.img}
                    alt={entry.data.img_alt || ""}
                    widths={[480, 720, 1200, entry.data.img.width]}
                    sizes={`(max-width: 720px) 100vw, 1200px`}
                    loading={"eager"}
                    class="hero-image"
                  />
                  <div class="image-overlay" />
                </div>
              )
            }
            <div class="content">
              <Content />
            </div>
          </div>
        </main>
      </div>
      <ContactCTA />
    </div>
  </div>
</BaseLayout>

<style>
  /* Base Layout Adjustments */
  .work-container {
    padding-bottom: 5rem;
  }

  header {
    padding-bottom: 2.5rem;
    position: relative;
  }

  /* Back Link Styles */
  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1rem;
    border-radius: 999px;
    background: var(--gray-999_40);
    backdrop-filter: blur(8px);
    border: 1px solid var(--gray-800);
    color: var(--gray-200);
    font-weight: 500;
    text-decoration: none;
    transition: all var(--theme-transition);
    width: fit-content;
    margin-bottom: 1rem;
  }

  .back-link:hover {
    background: var(--gray-900);
    color: var(--gray-0);
    transform: translateX(-2px);
    border-color: var(--gray-600);
  }

  /* Hero Section Styling */
  .hero-wrapper {
    position: relative;
    padding: 2rem 0;
  }

  /* Subtle background glow for Hero */
  .hero-wrapper::before {
    content: "";
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 140%;
    height: 140%;
    background: radial-gradient(
      circle,
      var(--accent-subtle-overlay) 0%,
      transparent 60%
    );
    opacity: 0.15;
    z-index: -1;
    pointer-events: none;
  }

  .details {
    display: flex;
    flex-direction: column;
    padding: 0.5rem;
    gap: 1.5rem;
    justify-content: space-between;
    align-items: flex-start;
  }

  .tags {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin-top: 0.5rem;
  }

  .description {
    font-size: var(--text-lg);
    max-width: 65ch;
    color: var(--gray-200);
    line-height: 1.6;
  }

  /* Hero Image Styling */
  .hero-image-container {
    position: relative;
    width: 100%;
    max-width: 1100px;
    margin-inline: auto;
    border-radius: 1.5rem;
    overflow: hidden;
    box-shadow: var(--shadow-lg);
    background: var(--gradient-subtle);
    border: 1px solid var(--gray-800);
    transition: all 0.5s cubic-bezier(0.23, 1, 0.32, 1);
  }

  .hero-image-container:hover {
    transform: scale(1.01) translateY(-4px);
    box-shadow: 0 20px 40px -10px var(--accent-overlay);
    border-color: var(--accent-regular);
  }

  .hero-image {
    width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
  }

  /* Content Typography & Layout */
  .content {
    max-width: 80ch; /* Increased from 65ch for wider reading area */
    width: 100%;
    margin-inline: auto;
    font-size: 1.125rem; /* Larger base font size (18px) */
    line-height: 1.75;
    color: var(--gray-200);
    padding: 0 1rem;
    overflow-wrap: anywhere;
  }

  /* Typography Enhancements */
  .content > :global(* + *) {
    margin-top: 1.5rem;
  }

  .content :global(h1),
  .content :global(h2),
  .content :global(h3),
  .content :global(h4) {
    margin: 3rem 0 1.5rem;
    color: var(--gray-0);
    line-height: 1.2;
    font-family: var(--font-brand);
  }

  .content :global(h1) {
    font-size: 2.5rem;
  }
  .content :global(h2) {
    font-size: 2rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--gray-800);
  }
  .content :global(h3) {
    font-size: 1.5rem;
  }

  /* Premium Blockquote */
  .content :global(blockquote) {
    font-size: 1.4rem;
    font-family: var(--font-brand);
    font-weight: 500;
    line-height: 1.4;
    margin: 2rem 0;
    padding: 1.5rem 2rem;
    border-left: 4px solid var(--accent-regular);
    background: linear-gradient(to right, var(--gray-999_40), transparent);
    border-radius: 0 1rem 1rem 0;
    color: var(--gray-0);
  }

  /* Enhanced Images in Content */
  .content :global(img) {
    border-radius: 1rem;
    box-shadow: var(--shadow-md);
    background: var(--gradient-subtle);
    border: 1px solid var(--gray-800);
    margin: 2rem auto;
    display: block;
    max-width: 100%;
    transition:
      transform 0.3s ease,
      box-shadow 0.3s ease;
  }

  .content :global(img:hover) {
    transform: scale(1.01);
    box-shadow: var(--shadow-lg);
  }

  /* Screenshot gallery grid — 2 columns, centered within content column.
     Markdown wraps each image in its own <p>, so those <p> tags are the grid
     children; we reset their default margins so the grid gaps are the only spacing. */
  .content :global(.screenshot-grid) {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1.75rem 1.25rem; /* row-gap column-gap */
    margin: 3rem auto;
    width: 100%;
    max-width: 640px;
    align-items: start;
    justify-items: stretch;
  }

  .content :global(.screenshot-grid p) {
    margin: 0;
    width: 100%;
  }

  .content :global(.screenshot-grid img) {
    margin: 0;
    width: 100%;
    height: auto;
    max-height: none;
    display: block;
  }

  @media (min-width: 50em) {
    .content :global(.screenshot-grid) {
      gap: 2.5rem 2rem;
      max-width: 720px;
    }
  }

  /* Code Blocks (if any) */
  .content :global(pre) {
    border-radius: 1rem;
    border: 1px solid var(--gray-800);
    padding: 1.5rem;
    background: var(
      --gray-999
    ) !important; /* Override theme default if needed */
    box-shadow: inset 0 2px 4px rgba(0, 0, 0, 0.02);
  }

  /* Links */
  .content :global(a) {
    color: var(--accent-regular);
    text-decoration: none;
    background-image: linear-gradient(
      var(--accent-regular),
      var(--accent-regular)
    );
    background-position: 0% 100%;
    background-repeat: no-repeat;
    background-size: 0% 2px;
    transition:
      background-size 0.3s,
      color 0.3s;
    font-weight: 500;
  }

  .content :global(a:hover) {
    background-size: 100% 2px;
    color: var(--accent-dark);
  }

  /* List Styling */
  .content :global(ul),
  .content :global(ol) {
    padding-left: 1.5rem;
    margin: 1.5rem 0;
  }

  .content :global(li) {
    margin-bottom: 0.75rem;
    position: relative;
  }

  .content :global(ul li) {
    list-style: none;
    padding-left: 0.5rem;
  }

  .content :global(ul li::before) {
    content: "•";
    position: absolute;
    left: -1rem;
    color: var(--accent-regular);
    font-weight: bold;
    font-size: 1.2em;
    line-height: 1.5rem;
  }

  .content :global(ol li) {
    padding-left: 0.5rem;
  }

  .content :global(ol li::marker) {
    color: var(--accent-regular);
    font-weight: 600;
    font-family: var(--font-brand);
  }

  /* Responsive Adjustments */
  @media (min-width: 50em) {
    .back-link {
      display: inline-flex; /* Ensure it stays visible */
    }

    .details {
      flex-direction: row;
      gap: 2.5rem;
      align-items: center;
    }

    .description {
      font-size: var(--text-xl);
    }
  }

  /* Animation Entry */
  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .content-wrapper {
    animation: fadeIn 0.6s ease-out forwards;
  }
</style>
