{
  "main": "@astrojs/cloudflare/entrypoints/server",
  "name": "kuldeep-dot-tech",
  "compatibility_date": "2026-01-13",
  "compatibility_flags": ["nodejs_compat", "global_fetch_strictly_public"],
  "assets": {
    "binding": "ASSETS",
    "directory": "./dist",
  },
  "observability": {
    "enabled": true,
  },
}
